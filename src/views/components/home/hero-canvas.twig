{% set frame_count = 120 %}
{% set frames_base_url = 'https://raw.githubusercontent.com/Dkhoni/theme-frames/main/' %}

<section
  id="hero-scroll-section"
  class="relative w-full"
  style="height: {{ frame_count * 6 }}px;"
  data-frame-count="{{ frame_count }}"
  data-base-url="{{ frames_base_url }}">

  <div id="hero-sticky"
       class="sticky top-0 w-full overflow-hidden"
       style="height: 100vh; background: teal;">

    <canvas id="hero-canvas" class="absolute inset-0 w-full h-full"></canvas>

    <div id="hero-loader"
         class="absolute inset-0 flex items-center justify-center"
         style="background:#1a4a3f;">
      <p style="color:white;font-size:24px;">Loading frames...</p>
      <div id="hero-progress" style="width:0%"></div>
    </div>

  </div>
</section>