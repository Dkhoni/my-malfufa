{#
  Hero Scroll Canvas Section
  File: src/views/components/home/hero-canvas.twig

  HOW IT WORKS:
  - The outer wrapper is tall (e.g. 500vh) to give scroll room
  - The inner canvas stays sticky/fixed while user scrolls through it
  - JavaScript maps scroll position → frame index → draws image on canvas
  - After all frames are done, the page scrolls normally again

  SETUP:
  - Upload your image sequence to Salla media library
  - Update the `data-frame-count` and `data-base-url` attributes below
  - Recommended: 60-120 frames, JPEG, ~1280×720px, <50KB each
  - Name them: frame_001.jpg, frame_002.jpg ... frame_120.jpg
#}

{# ─── How many frames in your sequence? ─── #}
{% set frame_count = 120 %}

{# ─── Base URL of your image sequence folder ─── #}
{# Upload frames to Salla media and paste the base URL here #}
{# Example: https://cdn.salla.sa/your-store/frames/ #}
{% set frames_base_url = theme.settings.get('hero_frames_url', 'https://raw.githubusercontent.com/Dkhoni/theme-frames/main/') %}

{# ─── Overlay text (editable from theme settings) ─── #}
{% set hero_title    = theme.settings.get('hero_title', store.name) %}
{% set hero_subtitle = theme.settings.get('hero_subtitle', store.slogan) %}
{% set hero_cta_text = theme.settings.get('hero_cta_text', 'Shop Now') %}
{% set hero_cta_url  = theme.settings.get('hero_cta_url', store.urls.products) %}

{# ════════════════════════════════════════════════════════
   SCROLL CANVAS WRAPPER
   Height = frame_count * scroll-per-frame (controlled in JS)
   ════════════════════════════════════════════════════════ #}
<section
  id="hero-scroll-section"
  class="relative w-full"
  style="height: {{ frame_count * 6 }}px;"
  data-frame-count="{{ frame_count }}"
  data-base-url="{{ frames_base_url }}"
  aria-label="Hero animation section">

  {# ── STICKY CONTAINER — stays on screen while section is in view ── #}
  <div id="hero-sticky"
       class="sticky top-0 w-full overflow-hidden"
       style="height: 100vh;">

    {# ── CANVAS — frames are drawn here ── #}
    <canvas
      id="hero-canvas"
      class="absolute inset-0 w-full h-full object-cover"
      aria-hidden="true">
    </canvas>

    {# ── DARK GRADIENT OVERLAY (makes text readable) ── #}
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-transparent to-black/60 pointer-events-none"></div>

    {# ── TEXT OVERLAY ── #}
    <div id="hero-content"
         class="absolute inset-0 flex flex-col items-center justify-end pb-20 px-6 text-center text-white z-10">

      {# Store logo / brand mark #}
      {% if store.logo %}
        <img src="{{ store.logo }}"
             alt="{{ store.name }}"
             class="h-12 w-auto object-contain mb-6 opacity-0 translate-y-4 transition-all duration-700 hero-reveal"
             style="filter: brightness(0) invert(1);" />
      {% endif %}

      {# Title #}
      <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-4 opacity-0 translate-y-4 transition-all duration-700 delay-100 hero-reveal">
        {{ hero_title }}
      </h1>

      {# Subtitle #}
      {% if hero_subtitle %}
        <p class="text-lg md:text-xl text-white/80 max-w-xl mb-8 opacity-0 translate-y-4 transition-all duration-700 delay-200 hero-reveal">
          {{ hero_subtitle }}
        </p>
      {% endif %}

      {# CTA Button #}
      <a href="{{ hero_cta_url }}"
         class="inline-flex items-center gap-2 bg-white text-[#1a4a3f] font-bold px-8 py-3.5 rounded-full text-base hover:bg-[#d4e8e2] transition-colors duration-200 shadow-lg opacity-0 translate-y-4 transition-all duration-700 delay-300 hero-reveal">
        {{ hero_cta_text }}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                d="{{ theme.is_rtl ? 'M15 19l-7-7 7-7' : 'M9 5l7 7-7 7' }}"/>
        </svg>
      </a>

    </div>

    {# ── SCROLL INDICATOR (bounces at start, hides as user scrolls) ── #}
    <div id="scroll-indicator"
         class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/70 text-xs font-medium z-10 transition-opacity duration-500">
      <span>{{ 'Scroll' }}</span>
      <div class="w-5 h-8 border-2 border-white/50 rounded-full flex items-start justify-center pt-1">
        <div class="w-1 h-2 bg-white/70 rounded-full animate-bounce"></div>
      </div>
    </div>

    {# ── LOADING INDICATOR (shown while frames preload) ── #}
    <div id="hero-loader"
         class="absolute inset-0 bg-[#1a4a3f] flex items-center justify-center z-20 transition-opacity duration-500">
      <div class="flex flex-col items-center gap-4">
        {% if store.logo %}
          <img src="{{ store.logo }}"
               alt="{{ store.name }}"
               class="h-10 w-auto object-contain"
               style="filter: brightness(0) invert(1);" />
        {% endif %}
        <div class="w-48 h-1 bg-white/20 rounded-full overflow-hidden">
          <div id="hero-progress"
               class="h-full bg-white rounded-full transition-all duration-100"
               style="width: 0%"></div>
        </div>
        <p class="text-white/50 text-xs tracking-widest uppercase">Loading...</p>
      </div>
    </div>

  </div>
</section>
