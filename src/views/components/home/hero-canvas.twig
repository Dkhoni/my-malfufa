<section
  id="hero-scroll-section"
  style="height: 720px; position: relative; width: 100%;">

  <div id="hero-sticky"
       style="position: sticky; top: 0; width: 100%; height: 100vh; background: #1a4a3f; display: flex; align-items: center; justify-content: center;">

    <canvas id="hero-canvas" style="position: absolute; inset: 0; width: 100%; height: 100%;"></canvas>

    <div id="hero-loader" style="position: absolute; inset: 0; background: #1a4a3f; display: flex; align-items: center; justify-content: center;">
      <p style="color: white; font-size: 24px;">Loading...</p>
    </div>

  </div>
</section>