{#
| Variable         | Type    | Description                     |
|------------------|---------|---------------------------------|
| cart             | object  |                                 |
| cart.items_count | int     |                                 |
| cart.total       | string  | Formatted total ex: "١٠٠ ر.س"   |
#}
<header class="site-header" id="site-header">

  <!-- NAVBAR -->
  <nav class="navbar">

    <!-- Logo — uses store's logo if set, otherwise store name -->
    <div class="navbar__logo">
      <a href="{{ store.url }}">
        {% if store.logo %}
          <img src="{{ store.logo }}" alt="{{ store.name }}" class="logo-img" />
        {% else %}
          <span class="logo-text">{{ store.name }}</span>
        {% endif %}
      </a>
    </div>

    <!-- Delivery / Pickup Toggle -->
    <div class="navbar__fulfillment">
      <button class="fulfillment-btn fulfillment-btn--active"
              id="btn-delivery"
              onclick="switchFulfillment('delivery')">Delivery</button>
      <button class="fulfillment-btn"
              id="btn-pickup"
              onclick="switchFulfillment('pickup')">Pickup</button>
    </div>

    <!-- Address Bar -->
    <div class="navbar__address">
      <div class="address-selector" onclick="openAddressModal()">
        <span>🚚</span>
        <span id="address-label">Select address</span>
      </div>
    </div>

    <!-- Right Actions -->
    <div class="navbar__actions">
      <!-- Built-in Salla language switcher -->
      <salla-localization-modal type="dropdown"></salla-localization-modal>

      <!-- Cart with item count (built-in Salla component) -->
      <a href="{{ store.urls.cart }}" class="action-btn">
        <salla-cart-summary icon="bag"></salla-cart-summary>
      </a>

      <!-- Menu button -->
      <button class="action-btn" onclick="toggleMobileMenu()">☰</button>
    </div>
  </nav>

  <!-- CATEGORY FILTER BAR -->
  <div class="category-bar">
    <button class="category-bar__search" onclick="openSearch()">🔍</button>

    <div class="category-bar__pills">
      {% for category in store.categories | slice(0, 5) %}
        <a href="{{ category.url }}"
           class="category-pill {{ category.id == current_category_id ? 'category-pill--active' : '' }}">
          {{ category.name }}
        </a>
      {% endfor %}
    </div>

    <button class="category-bar__more" onclick="toggleMoreCategories()">More ∨</button>
  </div>

</header>

<!-- Salla's search modal (opens when you call openSearch()) -->
<salla-search></salla-search>